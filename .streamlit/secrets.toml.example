# Copy this file to secrets.toml and fill in your real values.
# secrets.toml is git-ignored and must NEVER be committed.

# ── Azure Blob Storage ─────────────────────────────────────────────────────────
[azure]
account_name   = "your-storage-account-name"
container_name = "your-container-name"
sas_token      = "sp=r&st=...your-sas-token..."

# ── Authentication cookie ──────────────────────────────────────────────────────
[cookie]
name        = "adjust_auth"
key         = "REPLACE-WITH-RANDOM-STRING-AT-LEAST-32-CHARS"
expiry_days = 30

# ── User accounts ─────────────────────────────────────────────────────────────
# Generate hashed passwords by running:  python generate_password_hash.py

[credentials.alice]
name     = "Alice"
email    = "alice@yourcompany.com"
password = "$2b$12$<bcrypt-hash-here>"

[credentials.bob]
name     = "Bob"
email    = "bob@yourcompany.com"
password = "$2b$12$<bcrypt-hash-here>"
